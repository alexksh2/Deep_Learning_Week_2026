# OpenAI (required for chat, router, resume analysis, interview, and RAG)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-4o-mini

# Optional per-feature model overrides
# OPENAI_MODEL_FAST=gpt-4o-mini
# OPENAI_MODEL_CAPABLE=gpt-4o
# OPENAI_MODEL_ROUTER_LABELER=gpt-4o-mini
# OPENAI_MODEL_RAG=gpt-4o-mini
# OPENAI_MODEL_RESUME=gpt-4o-mini
# OPENAI_MODEL_INTERVIEW=gpt-4o-mini
# OPENAI_MODEL_CONTEXT=gpt-4o-mini

# Alpaca Paper Trading credentials
# Get these from https://app.alpaca.markets -> Paper Trading -> API Keys
ALPACA_API_KEY=your_paper_api_key_here
ALPACA_SECRET_KEY=your_paper_secret_key_here

# Alpaca endpoints (defaults shown; change only if you know what you're doing)
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# Optional: Smart Beta cache TTL (seconds, default 86400)
# SMART_BETA_CACHE_TTL=86400

# Legacy/local overrides (kept for compatibility with older scripts)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2
# GROQ_API_KEY=your_groq_api_key_here
